# AI Gateway Hono Backend
# Copy to .env for local/VPS test, or pass env directly in PM2

# Hono backend port
HONO_PORT=18323

# CRITICAL: production/test DB path used by Zhen VPS runtime
# Do not change unless explicitly approved.
DATA_DIR=/root/.9router

# Must match frontend JWT_SECRET
JWT_SECRET=change-me-same-as-frontend

# Use false for HTTP/IP testing. Use true only behind HTTPS domain.
AUTH_COOKIE_SECURE=false

# Optional fallback password only used if no password hash exists in DB settings
INITIAL_PASSWORD=change-me
